<UserControl x:Class="Assignment.Views.ToDoItemView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Assignment.Views"
             mc:Ignorable="d" 
             Height="Auto" Width="Auto" Padding="10">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="20"/>
        </Grid.ColumnDefinitions>
        
        <TextBlock Grid.Column="0" Text="{Binding ToDo.Name}" TextWrapping="Wrap"/>
        <TextBlock Grid.Column="1" Text="{Binding ToDo.Priority}" HorizontalAlignment="Right"/>
    </Grid>
    
    <UserControl.Style>
        <Style TargetType="UserControl">
            <Setter Property="Background" Value="Transparent"/>

            <Style.Triggers>
                <DataTrigger Binding="{Binding ToDo.Priority}" Value="1">
                    <Setter Property="Background" Value="Red"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding ToDo.Priority}" Value="2">
                    <Setter Property="Background" Value="Yellow"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding ToDo.Priority}" Value="3">
                    <Setter Property="Background" Value="Green"/>
                </DataTrigger>
            </Style.Triggers>

        </Style>
    </UserControl.Style>
</UserControl>
